generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum SystemRole {
  SUPER_USER
  ADMIN
  EMPLOYEE
}

enum ShiftType {
  DAY
  AFTERNOON
  NIGHT
}

enum ProjectType {
  DEDICATED
  T_AND_M
  FIXED
}

enum ProjectStatus {
  ACTIVE
  ARCHIVE
  ON_HOLD
}

enum ProjectRole {
  PROJECT_MANAGER
  TEAM_LEAD
  DEVELOPER
  QA
  DESIGNER
  DEVOPS
}

enum MilestoneStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  DELAYED
}

enum TaskListType {
  GENERAL
  PROJECT_MANAGEMENT
  DEVELOPMENT
  QA
  SPRINT
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  ON_REVIEW
  COMPLETED
}

enum BillingStatus {
  BILLABLE
  NON_BILLABLE
}

// ─── Department ───────────────────────────────────────────────────────────────

model Department {
  id        String   @id @default(uuid())
  name      String   @unique @db.VarChar(100)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  projects Project[]

  @@map("departments")
}

// ─── Auth Models ──────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  fullName     String     @db.VarChar(100)
  email        String     @unique @db.VarChar(255)
  passwordHash String
  systemRole   SystemRole @default(EMPLOYEE)
  phone        String?    @db.VarChar(20)
  joinDate     DateTime?  @db.Date
  profilePhoto String?
  departmentId String?
  shiftId      String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  lastLoginAt  DateTime?

  department    Department?  @relation(fields: [departmentId], references: [id])
  shift         Shift?       @relation(fields: [shiftId], references: [id])
  refreshTokens         RefreshToken[]
  projectMembers        ProjectMember[]
  responsibleMilestones Milestone[]
  assignedTasks         Task[]         @relation("AssignedTasks")
  createdTasks          Task[]         @relation("CreatedTasks")
  uploadedAttachments   TaskAttachment[] @relation("UploadedAttachments")
  authoredComments      TaskComment[]   @relation("AuthoredComments")

  @@index([email])
  @@map("users")
}

model CompanySettings {
  id               String   @id @default("singleton")
  companyName      String   @default("") @db.VarChar(200)
  webAddress       String?
  street           String?
  city             String?
  state            String?
  country          String   @default("India")
  zipCode          String?  @db.VarChar(20)
  timezone         String   @default("Asia/Kolkata")
  backDateLogValue Int      @default(8)
  backDateLogUnit  String   @default("Days") @db.VarChar(10)
  emailDomains     String[]
  updatedAt        DateTime @updatedAt

  @@map("company_settings")
}

model PortalConfig {
  id                       String   @id @default("singleton")
  dateFormat               String   @default("DD-MM-YYYY") @db.VarChar(20)
  timeFormat               String   @default("24") @db.VarChar(4)
  taskDurationIn           String   @default("hours") @db.VarChar(10)
  firstDayOfWeek           String   @default("Monday") @db.VarChar(10)
  businessHoursStart       String   @default("10:00") @db.VarChar(6)
  businessHoursStartPeriod String   @default("AM") @db.VarChar(2)
  businessHoursEnd         String   @default("07:00") @db.VarChar(6)
  businessHoursEndPeriod   String   @default("PM") @db.VarChar(2)
  workingDays              Json     @default("{\"monday\":true,\"tuesday\":true,\"wednesday\":true,\"thursday\":true,\"friday\":true,\"saturday\":false,\"sunday\":false}")
  updatedAt                DateTime @updatedAt

  @@map("portal_config")
}

model Shift {
  id        String    @id @default(uuid())
  name      String    @db.VarChar(50)
  shiftType ShiftType @unique
  startTime String    @db.VarChar(8)
  endTime   String    @db.VarChar(8)
  workHours Int       @default(8)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users User[]

  @@map("shifts")
}

model Holiday {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(100)
  date        DateTime @db.Date
  isRecurring Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([date])
  @@map("holidays")
}

// ─── Project ──────────────────────────────────────────────────────────────────

model Project {
  id           String        @id @default(uuid())
  name         String        @db.VarChar(200)
  clientId     String?
  departmentId String?
  description  String?       @db.VarChar(1000)
  startDate    DateTime?     @db.Date
  endDate      DateTime?     @db.Date
  budget       Decimal?      @db.Decimal(12, 2)
  projectType  ProjectType
  status       ProjectStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  client     Client?         @relation(fields: [clientId], references: [id])
  department Department?     @relation(fields: [departmentId], references: [id])
  members    ProjectMember[]
  milestones Milestone[]
  taskLists  TaskList[]
  tasks      Task[]

  @@index([status])
  @@index([projectType])
  @@map("projects")
}

// ─── Milestone ────────────────────────────────────────────────────────────────

model Milestone {
  id                String          @id @default(uuid())
  projectId         String
  description       String          @db.VarChar(500)
  deliveryNote      String?         @db.VarChar(1000)
  startDate         DateTime?       @db.Date
  dueDate           DateTime?       @db.Date
  responsibleUserId String?
  status            MilestoneStatus @default(NOT_STARTED)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  project         Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  responsibleUser User?   @relation(fields: [responsibleUserId], references: [id], onDelete: SetNull)
  tasks           Task[]

  @@index([projectId])
  @@map("milestones")
}

// ─── Task List ────────────────────────────────────────────────────────────────

model TaskList {
  id           String       @id @default(uuid())
  projectId    String
  name         String       @db.VarChar(200)
  type         TaskListType
  sprintNumber Int?
  description  String?      @db.VarChar(500)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId])
  @@map("task_lists")
}

// ─── Task ─────────────────────────────────────────────────────────────────────

model Task {
  id             String        @id @default(uuid())
  projectId      String
  taskListId     String
  milestoneId    String?
  title          String        @db.VarChar(300)
  description    String?       @db.VarChar(2000)
  assignedToId   String?
  createdById    String
  estimatedHours Decimal?      @db.Decimal(6, 2)
  priority       TaskPriority  @default(MEDIUM)
  billingStatus  BillingStatus @default(BILLABLE)
  status         TaskStatus    @default(NOT_STARTED)
  startDate      DateTime?     @db.Date
  dueDate        DateTime?     @db.Date
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskList   TaskList  @relation(fields: [taskListId], references: [id], onDelete: Cascade)
  milestone  Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  assignedTo User?     @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy  User      @relation("CreatedTasks", fields: [createdById], references: [id])
  attachments TaskAttachment[]
  comments    TaskComment[]

  @@index([projectId])
  @@index([taskListId])
  @@index([assignedToId])
  @@map("tasks")
}

// ─── Task Attachment ──────────────────────────────────────────────────────────

model TaskAttachment {
  id           String   @id @default(uuid())
  taskId       String
  filename     String   @db.VarChar(255)
  originalName String   @db.VarChar(255)
  mimeType     String   @db.VarChar(100)
  size         Int
  uploadedById String
  createdAt    DateTime @default(now())

  task       Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User @relation("UploadedAttachments", fields: [uploadedById], references: [id])

  @@index([taskId])
  @@map("task_attachments")
}

// ─── Task Comment ─────────────────────────────────────────────────────────────

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  content   String   @db.VarChar(2000)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation("AuthoredComments", fields: [authorId], references: [id])

  @@index([taskId])
  @@map("task_comments")
}

// ─── Project Member ───────────────────────────────────────────────────────────

model ProjectMember {
  id          String      @id @default(uuid())
  projectId   String
  userId      String
  projectRole ProjectRole
  joinedAt    DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@map("project_members")
}

// ─── Client ───────────────────────────────────────────────────────────────────

model Client {
  id            String   @id @default(uuid())
  name          String   @unique @db.VarChar(150)
  contactPerson String   @db.VarChar(100)
  email         String   @db.VarChar(255)
  phone         String?  @db.VarChar(20)
  address       String?  @db.VarChar(300)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projects Project[]

  @@map("clients")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}
